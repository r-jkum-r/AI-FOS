<?xml version="1.0" encoding="UTF-8"?>
<include>
  <context name="voice-agent">

    <!-- Incoming PSTN/SIP calls (Indian mobile numbers) -->
    <extension name="incoming-call">
      <condition field="destination_number" expression="^(\+?91)?[6-9][0-9]{9}$">
        <action application="log" data="INFO: Incoming call from ${caller_id_number} to ${destination_number}"/>
        <action application="answer"/>
        <action application="set" data="call_uuid=${uuid}"/>
        <action application="set" data="call_start_time=${strftime(%s)}"/>
        <action application="set" data="voice_gateway_url=http://backend:8000"/>
        <action application="bridge" data="sofia/sip/backend:8000"/>
        <action application="log" data="ERROR: Bridge failed for call ${uuid}"/>
        <action application="hangup" data="NORMAL_CLEARING"/>
      </condition>
    </extension>

    <!-- SIP URI calls -->
    <extension name="sip-incoming">
      <condition field="destination_number" expression="^sip:.+">
        <action application="log" data="INFO: SIP call from ${sip_from_uri}"/>
        <action application="answer"/>
        <action application="bridge" data="sofia/sip/backend:8000"/>
      </condition>
    </extension>

    <!-- Outbound to IT team -->
    <extension name="call-it-team">
      <condition field="destination_number" expression="^it-team$">
        <action application="log" data="INFO: Routing translated call to IT Team"/>
        <action application="set" data="call_type=outbound"/>
        <action application="set" data="target_language=hin_Deva"/>
        <action application="bridge" data="sofia/sip/it-team@${kamailio_dispatcher}"/>
      </condition>
    </extension>

    <!-- Test extension -->
    <extension name="test-extension">
      <condition field="destination_number" expression="^9999$">
        <action application="answer"/>
        <action application="playback" data="ivr/ivr-hello.wav"/>
        <action application="hangup"/>
      </condition>
    </extension>

    <!-- Default catch-all -->
    <extension name="default">
      <condition>
        <action application="log" data="WARNING: No matching extension for ${destination_number}"/>
        <action application="hangup" data="CALL_REJECTED"/>
      </condition>
    </extension>

  </context>
</include>
